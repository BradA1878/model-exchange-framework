{
    "identifier": "default",
    "description": "Default capabilities for the MXF desktop app",
    "windows": ["main"],
    "permissions": [
        "core:default",
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "name": "bun",
                    "cmd": "bun",
                    "args": true
                }
            ]
        },
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "name": "bun",
                    "cmd": "bun",
                    "args": true
                }
            ]
        },
        "shell:allow-open",
        "shell:allow-stdin-write",
        "shell:allow-kill",
        "clipboard-manager:allow-read-text",
        "clipboard-manager:allow-write-text",
        "notification:default",
        "dialog:default",
        "fs:default",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-read-text-file",
        "fs:allow-write-text-file",
        "fs:allow-exists",
        "fs:allow-mkdir",
        "fs:allow-read-dir",
        "fs:scope-home-recursive"
    ]
}
