{
    "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/tooling/cli/schema.json",
    "productName": "MXF",
    "version": "0.1.0",
    "identifier": "com.mxf.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5199",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "MXF",
                "width": 900,
                "height": 700,
                "minWidth": 600,
                "minHeight": 400,
                "resizable": true,
                "decorations": true,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["dmg", "app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "DeveloperTool",
        "shortDescription": "MXF — Multi-Agent AI Orchestration",
        "longDescription": "Model Exchange Framework desktop application. Multi-agent AI collaboration system with real-time task orchestration, rich markdown rendering, and native keyboard handling.",
        "macOS": {
            "minimumSystemVersion": "12.0",
            "frameworks": []
        }
    },
    "plugins": {
        "shell": {
            "open": true
        }
    }
}
