{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "jest",
  "jest": {
    "configFile": "tests/jest.unit.config.ts"
  },
  "checkers": [],
  "mutate": [
    "packages/core/src/schemas/**/*.ts",
    "packages/core/src/protocols/mcp/McpToolCallParser.ts",
    "packages/core/src/protocols/mcp/McpToolSchema.ts",
    "packages/core/src/utils/validation.ts",
    "packages/core/src/utils/TokenEstimator.ts",
    "packages/core/src/utils/MxpEncryption.ts",
    "packages/core/src/utils/env.ts",
    "packages/core/src/types/TaskTypes.ts",
    "packages/core/src/services/CodeExecutionSandboxService.ts",
    "packages/core/src/services/QValueManager.ts",
    "packages/core/src/services/RewardSignalProcessor.ts",
    "packages/core/src/services/orpar-memory/PhaseStrataRouter.ts",
    "packages/core/src/services/orpar-memory/PhaseWeightedRewarder.ts",
    "packages/sdk/src/managers/MxfMemoryManager.ts",
    "!**/*.test.ts",
    "!**/*.spec.ts",
    "!**/index.ts"
  ],
  "ignorePatterns": [
    "**/.claude/**",
    "node_modules/**",
    "dist/**",
    ".stryker-tmp/**",
    "**/*.sock"
  ],
  "timeoutMS": 10000,
  "concurrency": 4,
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 70,
    "low": 45,
    "break": null
  },
  "disableTypeChecks": "**/*.ts",
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json"
}
