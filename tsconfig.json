{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@mxf-dev/core": ["packages/core/src/index.ts"],
      "@mxf-dev/core/*": ["packages/core/src/*"],
      "@mxf-dev/sdk": ["packages/sdk/src/index.ts"],
      "@mxf-dev/sdk/*": ["packages/sdk/src/*"]
    },
    "rootDir": "src",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/sdk" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "src/cli/tui/**/*",
    "src/desktop/**/*"
  ]
}
